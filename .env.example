# Groq Cloud LLM API key (optional — only needed for Groq endpoints)
GROQ_API_KEY=your_groq_api_key_here

# API base URL used by the dashboard (change if running outside Docker)
API_BASE_URL=http://localhost:4000

# ── LM Studio (local) ────────────────────────────────────────────────────────
# host.docker.internal resolves to your Mac/Windows host from inside Docker.
# On Linux Docker Engine, docker-compose adds host-gateway automatically.
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=local-model
