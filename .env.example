# ─────────────────────────────────────────────────────────────────
# LOGIC Web Agent — Environment Configuration
# Copy this file to .env and fill in ALL values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Security (REQUIRED in production) ────────────────────────────
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-generate-with-python-secrets

# JWT token lifetime in minutes (default: 60 min)
JWT_EXPIRE_MINUTES=60

# ── Groq AI (REQUIRED for AI chat and threat-insights features) ──
# Get your free key from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Network ───────────────────────────────────────────────────────
# URL of the FastAPI backend (used by Next.js server-side proxy).
# Same-server deployment:  http://localhost:4000
# Behind Nginx / domain:   https://api.your-tool.company.com
API_BASE_URL=http://localhost:4000

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins for the API.
# Development:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example (replace with your actual domain):
# ALLOWED_ORIGINS=https://your-tool.company.com

# ── Data paths ────────────────────────────────────────────────────
# Root of the data directory. Normally leave as default.
DATA_ROOT=./data

# ── LM Studio (optional — local LLM alternative) ─────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
